  69:src/memoryAllocator.cpp **** /**
  70:src/memoryAllocator.cpp ****  * Frees previously allocated memory block.
  71:src/memoryAllocator.cpp ****  * @param ptr Pointer returned by kmem_alloc.
  72:src/memoryAllocator.cpp ****  * @return Error codes:
  73:src/memoryAllocator.cpp ****  *         0 (success),
  74:src/memoryAllocator.cpp ****  *        -1 (null pointer or heap not initialized),
  75:src/memoryAllocator.cpp ****  *        -2 (pointer out of heap),
  76:src/memoryAllocator.cpp ****  *        -3 (invalid pointer, not previously allocated or corrupted)
  77:src/memoryAllocator.cpp ****  */
  78:src/memoryAllocator.cpp **** int MemoryAllocator::kmem_free(void* ptr) {
  79:src/memoryAllocator.cpp ****     if (!ptr) return -1;
  80:src/memoryAllocator.cpp ****     if ((char*)ptr < (char*)HEAP_START_ADDR || (char*)ptr > (char*)HEAP_END_ADDR) return -2;
  81:src/memoryAllocator.cpp **** 
  82:src/memoryAllocator.cpp ****     ChunkHeader* chunkHeader = (ChunkHeader*)((char*)ptr - sizeof(ChunkHeader));
  83:src/memoryAllocator.cpp ****     if(chunkHeader->magic != MAGIC) return -3;
  84:src/memoryAllocator.cpp **** 
  85:src/memoryAllocator.cpp ****     chunkHeader->free = true;
  86:src/memoryAllocator.cpp **** 
  87:src/memoryAllocator.cpp ****     // Try joining with free neighbours
  88:src/memoryAllocator.cpp ****     try_join(chunkHeader);
  89:src/memoryAllocator.cpp **** 
  90:src/memoryAllocator.cpp ****     return 0;
  91:src/memoryAllocator.cpp **** }
