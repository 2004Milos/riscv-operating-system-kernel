  74:src/memory_allocator.cpp **** /**
  75:src/memory_allocator.cpp ****  * Frees previously allocated memory block.
  76:src/memory_allocator.cpp ****  * @param ptr Pointer returned by kmem_alloc.
  77:src/memory_allocator.cpp ****  * @return Error codes:
  78:src/memory_allocator.cpp ****  *         0 (success),
  79:src/memory_allocator.cpp ****  *        -1 (null pointer or heap not initialized),
  80:src/memory_allocator.cpp ****  *        -2 (pointer out of heap),
  81:src/memory_allocator.cpp ****  *        -3 (invalid pointer, not previously allocated or corrupted)
  82:src/memory_allocator.cpp ****  */
  83:src/memory_allocator.cpp **** int MemoryAllocator::kmem_free(void* ptr) {
  84:src/memory_allocator.cpp ****     if (!ptr) return -1;
  85:src/memory_allocator.cpp ****     if ((char*)ptr < (char*)HEAP_START_ADDR || (char*)ptr > (char*)HEAP_END_ADDR) return -2;
  86:src/memory_allocator.cpp **** 
  87:src/memory_allocator.cpp ****     ChunkHeader* chunkHeader = (ChunkHeader*)((char*)ptr - sizeof(ChunkHeader));
  88:src/memory_allocator.cpp ****     if(chunkHeader->magic != MAGIC) return -3;
  89:src/memory_allocator.cpp **** 
  90:src/memory_allocator.cpp ****     chunkHeader->free = true;
  91:src/memory_allocator.cpp **** 
  92:src/memory_allocator.cpp ****     // Try joining with free neighbours
  93:src/memory_allocator.cpp ****     try_join(chunkHeader);
  94:src/memory_allocator.cpp **** 
  95:src/memory_allocator.cpp ****     return 0;
  96:src/memory_allocator.cpp **** }
