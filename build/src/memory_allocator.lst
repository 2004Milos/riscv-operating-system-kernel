  72:src/memory_allocator.cpp **** /**
  73:src/memory_allocator.cpp ****  * Frees previously allocated memory block.
  74:src/memory_allocator.cpp ****  * @param ptr Pointer returned by kmem_alloc.
  75:src/memory_allocator.cpp ****  * @return Error codes:
  76:src/memory_allocator.cpp ****  *         0 (success),
  77:src/memory_allocator.cpp ****  *        -1 (null pointer or heap not initialized),
  78:src/memory_allocator.cpp ****  *        -2 (pointer out of heap),
  79:src/memory_allocator.cpp ****  *        -3 (invalid pointer, not previously allocated or corrupted)
  80:src/memory_allocator.cpp ****  */
  81:src/memory_allocator.cpp **** int MemoryAllocator::kmem_free(void* ptr) {
  82:src/memory_allocator.cpp ****     if (!ptr) return -1;
  83:src/memory_allocator.cpp ****     if ((char*)ptr < (char*)HEAP_START_ADDR || (char*)ptr > (char*)HEAP_END_ADDR) return -2;
  84:src/memory_allocator.cpp **** 
  85:src/memory_allocator.cpp ****     ChunkHeader* chunkHeader = (ChunkHeader*)((char*)ptr - sizeof(ChunkHeader));
  86:src/memory_allocator.cpp ****     if(chunkHeader->magic != MAGIC || chunkHeader->free) return -3;
  87:src/memory_allocator.cpp **** 
  88:src/memory_allocator.cpp ****     chunkHeader->free = true;
  89:src/memory_allocator.cpp **** 
  90:src/memory_allocator.cpp ****     // Try joining with free neighbours
  91:src/memory_allocator.cpp ****     try_join(chunkHeader);
  92:src/memory_allocator.cpp **** 
  93:src/memory_allocator.cpp ****     return 0;
  94:src/memory_allocator.cpp **** }
